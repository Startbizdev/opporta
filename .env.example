# Copier vers .env.local (jamais commité). Sur Vercel : Settings → Environment Variables.

# Database — même URL que dans Neon « Connection string » (branche pooled / -pooler).
# Ne pas mettre de guillemets autour de l’URL sur Vercel.
# Si erreur Prisma en prod : essayer sans &channel_binding=require à la fin.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# NextAuth (prod : https://ton-projet.vercel.app sans slash final)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generer-avec-openssl-rand-base64-32

# Resend (optionnel)
RESEND_API_KEY=re_xxxxxxxx

# Optionnel : flo@opporta.fr,aless@opporta.fr
# DEMO_LOGIN_EMAILS=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Copier vers .env.local (jamais commité). Sur Vercel : Settings → Environment Variables.

# Database (Neon : URL « pooled » / -pooler pour Vercel serverless)
# Si Prisma échoue : sslmode=require ; enlever channel_binding=require si présent.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# NextAuth (en prod : https://ton-domaine.vercel.app, sans slash final)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generer-avec-openssl-rand-base64-32

# Resend (optionnel — magic link ; sans ça, la page login utilise seulement ensure-user)
RESEND_API_KEY=re_xxxxxxxx

# Optionnel en prod : e-mails autorisés pour la connexion sans lien (séparés par des virgules).
# Si défini, les autres reçoivent 403. En local tu peux laisser vide pour accepter n’importe quel e-mail.
# DEMO_LOGIN_EMAILS=flo@opporta.fr,aless@opporta.fr

# Doit matcher l’URL publique du site (liens dans les emails, redirections)
NEXT_PUBLIC_APP_URL=http://localhost:3000
